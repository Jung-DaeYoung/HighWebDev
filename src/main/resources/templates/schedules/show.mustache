{{>layouts/header}}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            {{#schedule}}
                <div class="card shadow">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">{{title}}</h4>
                        <span class="badge bg-info">ID: {{id}}</span>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <h6 class="text-muted border-bottom pb-2">⏰ 마감 기한</h6>
                            <p class="lead">{{displayDeadline}}</p>
                        </div>
                        <div class="mb-4">
                            <h6 class="text-muted border-bottom pb-2">📝 세부 내용</h6>
                            <p class="card-text" style="white-space: pre-wrap;">{{content}}</p>
                        </div>
                        <div class="text-end text-muted small">
                            등록일: {{createdAt}}
                        </div>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between">
                        <a href="/schedules" class="btn btn-outline-secondary">목록으로</a>
                        <div>
                            <a href="/schedules/{{id}}/edit" class="btn btn-success">수정하기</a>
                            <a href="/schedules/{{id}}/delete" class="btn btn-danger" onclick="return confirm('정말 삭제하시겠습니까?')">삭제하기</a>
                        </div>
                    </div>
                </div>
            {{/schedule}}
            {{^schedule}}
                <div class="alert alert-warning text-center">
                    존재하지 않는 일정입니다. <br>
                    <a href="/schedules" class="alert-link">목록으로 돌아가기</a>
                </div>
            {{/schedule}}
        </div>
    </div>
</div>

{{>layouts/footer}}
