{{>layouts/header}}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0" style="border-radius:16px; border: 1.5px solid #b6c8f5 !important;">
                <div class="card-header bg-white border-bottom" style="border-radius:16px 16px 0 0; padding: 20px 24px 16px;">
                    <h4 class="fw-bold mb-0" style="color:#0a0a0a;">새 일정 등록</h4>
                </div>
                <div class="card-body" style="padding: 24px;">
                    <form action="/schedules/create" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold" style="color:#1a1a1a;">제목</label>
                            <input type="text" class="form-control" name="title" placeholder="무엇을 해야 하나요?" required
                                   style="border-radius:8px; border:1.5px solid #b6c8f5; padding: 10px 14px;">
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold" style="color:#1a1a1a;">세부 내용</label>
                            <textarea class="form-control" name="content" rows="4" placeholder="상세 내용을 적어주세요."
                                      style="border-radius:8px; border:1.5px solid #b6c8f5; padding: 10px 14px;"></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold" style="color:#1a1a1a;">마감 기한</label>
                            <input type="datetime-local" class="form-control" name="deadline" required
                                   style="border-radius:8px; border:1.5px solid #b6c8f5; padding: 10px 14px;">
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="/" class="btn btn-outline-primary fw-bold px-4" style="border-radius:8px; border-width:1.5px;">취소</a>
                            <button type="submit" class="btn btn-primary fw-bold px-4" style="border-radius:8px;">등록하기</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{>layouts/footer}}